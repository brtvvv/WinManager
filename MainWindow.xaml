<Window x:Class="WinManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WinManager.ViewModels"
        xmlns:model="clr-namespace:WinManager.Models"
        mc:Ignorable="d"
        Title="WinManager - Programs &amp; Features"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <!-- Root grid: left sidebar + top bar + content -->
    <Grid Background="{StaticResource PrimaryDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Left sidebar navigation: primary sections -->
        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Margin="16,16,10,16"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Navigation"
                           Margin="14,14,14,6"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <ItemsControl>
                    <ItemsControl.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Resources>
                    <ItemsControl.Items>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Programs}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Programs}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Programs &amp; Features" FontWeight="SemiBold" />
                                    <TextBlock Text="Manage Windows and external apps" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Optimization}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Optimization}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Optimization" FontWeight="SemiBold" />
                                    <TextBlock Text="Performance tweaks" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Customization}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Customization}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Customization" FontWeight="SemiBold" />
                                    <TextBlock Text="UI &amp; personalization" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </ItemsControl.Items>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Top bar: title + status -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="0,16,16,8"
                Padding="18"
                Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Windows Programs &amp; Features"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Install, uninstall and manage Windows and external apps."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Setter Property="Text" Value="Administrator: NO (run as admin for full functionality)" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Programs.IsAdministrator}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Setter Property="Text" Value="Administrator: YES (elevated)" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Programs.IsAdministrator}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Setter Property="Text" Value="Administrator: NO (some actions need elevation)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Programs.Status}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content area: switches by SelectedSection -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,16,16">
            <!-- Programs & Features content -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Programs}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="14"
                        Padding="14"
                        BorderBrush="{StaticResource BorderBrushMono}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Manage applications"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Select apps (all / installed / not installed) then Install or Uninstall."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Inner tabs for Windows vs External apps -->
                <TabControl Grid.Row="1"
                            Margin="0,14,0,0"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabItem Header="Windows Apps">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource SurfaceBrush}"
                                    Padding="14"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox Width="220"
                                                 Text="{Binding Programs.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,8,0" />
                                        <Button Content="Select all" Command="{Binding Programs.SelectAllCommand}" />
                                        <Button Content="Installed only" Command="{Binding Programs.SelectInstalledCommand}" />
                                        <Button Content="Not installed only" Command="{Binding Programs.SelectNotInstalledCommand}" />
                                        <Button Content="Clear selection" Command="{Binding Programs.ClearSelectionCommand}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Refresh"
                                                Command="{Binding Programs.RefreshCommand}" />
                                        <Button Content="Install selected"
                                                Command="{Binding Programs.InstallWindowsCommand}" />
                                        <Button Content="Uninstall selected"
                                                Command="{Binding Programs.UninstallWindowsCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    Padding="10"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Programs.WindowsAppsView}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemWidth="360" MinWidth="360" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Margin" Value="8" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="12"
                                                        Padding="12"
                                                        BorderBrush="{StaticResource BorderBrushMono}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,10,0">
                                                            <CheckBox IsChecked="{Binding IsSelected}" />
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Orientation="Vertical">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" />
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                <TextBlock Text="Status:" Foreground="{StaticResource TextSecondaryBrush}" />
                                                                <TextBlock Text="{Binding Status}" FontWeight="SemiBold" Margin="6,0,0,0" />
                                                            </StackPanel>
                                                            <TextBlock Text="{Binding StatusNote}" Foreground="{StaticResource MutedBrush}" FontSize="11" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="External Apps">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    Padding="14"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Select all" Command="{Binding Programs.SelectAllExternalCommand}" />
                                    <Button Content="Clear selection" Command="{Binding Programs.ClearExternalCommand}" />
                                    <Button Content="Install selected"
                                            Command="{Binding Programs.InstallExternalCommand}" />
                                    <Button Content="Uninstall selected"
                                            Command="{Binding Programs.UninstallExternalCommand}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    Padding="10"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <ListView ItemsSource="{Binding Programs.ExternalAppsView}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Background="{StaticResource SurfaceAltBrush}"
                                          BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="40">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Description" Width="400">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Package" Width="240">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding WingetId}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Optimization placeholder -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Optimization}">
                <TextBlock Text="{Binding OptimizationMessage}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>

            <!-- Customization placeholder -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Customization}">
                <TextBlock Text="{Binding CustomizationMessage}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </Grid>
    </Grid>
</Window>

