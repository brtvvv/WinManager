<Window x:Class="WinManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:WinManager.ViewModels"
        xmlns:model="clr-namespace:WinManager.Models"
        xmlns:optvm="clr-namespace:WinManager.ViewModels.Optimization"
        xmlns:optv="clr-namespace:WinManager.Views.Optimization"
        xmlns:views="clr-namespace:WinManager.Views"
        mc:Ignorable="d"
        Title="WinManager"
        Height="900"
        Width="1500"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>
    <!-- Root grid: left sidebar + top bar + content -->
    <Grid Background="{StaticResource PrimaryDarkBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Left sidebar navigation: primary sections -->
        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Margin="16,16,10,16"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Navigation"
                           Margin="14,14,14,6"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <ItemsControl>
                    <ItemsControl.Resources>
                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ItemsControl.Resources>
                    <ItemsControl.Items>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Programs}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Programs}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Programs &amp; Features" FontWeight="SemiBold" />
                                    <TextBlock Text="Manage Programs" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Optimization}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Optimization}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Optimization" FontWeight="SemiBold" />
                                    <TextBlock Text="Performance tweaks" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Customization}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Customization}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Customization" FontWeight="SemiBold" />
                                    <TextBlock Text="UI &amp; personalization" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SelectSectionCommand}" CommandParameter="{x:Static model:AppSection.Misc}">
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="6" Height="24" RadiusX="3" RadiusY="3" Fill="{StaticResource SurfaceAltBrush}">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <Setter Property="Opacity" Value="0" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSection}" Value="{x:Static model:AppSection.Misc}">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Setter Property="Fill" Value="{StaticResource BorderBrushMono}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                                    <TextBlock Text="Misc" FontWeight="SemiBold" />
                                    <TextBlock Text="Miscellaneous tweaks" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </ItemsControl.Items>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Top bar: title + status -->
        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="0,16,16,8"
                Padding="18"
                Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical" Margin="0,0,12,0">
                    <TextBlock Text="Windows Programs &amp; Features"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Text="Install, uninstall and manage Windows and external apps."
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                <Setter Property="Text" Value="Administrator: NO (run as admin for full functionality)" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Programs.IsAdministrator}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                        <Setter Property="Text" Value="Administrator: YES (elevated)" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Programs.IsAdministrator}" Value="False">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                        <Setter Property="Text" Value="Administrator: NO (some actions need elevation)" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Programs.Status}"
                               Margin="0,6,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content area: switches by SelectedSection -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,16,16">
            <!-- Programs & Features content -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Programs}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{StaticResource SurfaceBrush}"
                        CornerRadius="14"
                        Padding="14"
                        BorderBrush="{StaticResource BorderBrushMono}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Manage applications"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="Select apps (all / installed / not installed) then Install or Uninstall."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Inner tabs for Windows vs External apps -->
                <TabControl Grid.Row="1"
                            Margin="0,14,0,0"
                            Background="Transparent"
                            BorderThickness="0">
                    <TabItem Header="Windows Apps">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Background="{StaticResource SurfaceBrush}"
                                    Padding="14"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBox Width="220"
                                                 Text="{Binding Programs.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,8,0" />
                                        <Button Content="Select all" Command="{Binding Programs.SelectAllCommand}" />
                                        <Button Content="Installed only" Command="{Binding Programs.SelectInstalledCommand}" />
                                        <Button Content="Not installed only" Command="{Binding Programs.SelectNotInstalledCommand}" />
                                        <Button Content="Clear selection" Command="{Binding Programs.ClearSelectionCommand}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="Refresh"
                                                Command="{Binding Programs.RefreshCommand}" />
                                        <Button Content="Install selected"
                                                Command="{Binding Programs.InstallWindowsCommand}" />
                                        <Button Content="Uninstall selected"
                                                Command="{Binding Programs.UninstallWindowsCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    Padding="10"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Programs.WindowsAppsView}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal" ItemWidth="300" MinWidth="300" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Margin" Value="3" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="8"
                                                        Padding="10,7"
                                                        BorderBrush="{StaticResource BorderBrushMono}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                                  VerticalAlignment="Center" />
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="13"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Grid.Column="2"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Right"
                                                                   FontSize="14"
                                                                   Margin="8,0,2,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Text" Value="✕" />
                                                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}"
                                                                                     Value="{x:Static model:AppStatus.Installed}">
                                                                            <Setter Property="Text" Value="●" />
                                                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="External Apps">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Background="{StaticResource SurfaceBrush}"
                                    Padding="14"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Select all" Command="{Binding Programs.SelectAllExternalCommand}" />
                                    <Button Content="Clear selection" Command="{Binding Programs.ClearExternalCommand}" />
                                    <Button Content="Install selected"
                                            Command="{Binding Programs.InstallExternalCommand}" />
                                    <Button Content="Uninstall selected"
                                            Command="{Binding Programs.UninstallExternalCommand}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Background="{StaticResource SurfaceAltBrush}"
                                    Padding="10"
                                    CornerRadius="14"
                                    BorderBrush="{StaticResource BorderBrushMono}"
                                    BorderThickness="1">
                                <ListView ItemsSource="{Binding Programs.ExternalAppsView}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          Background="{StaticResource SurfaceAltBrush}"
                                          BorderThickness="0">
                                    <ListView.View>
                                        <GridView>
                                            <GridViewColumn Width="40">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <CheckBox IsChecked="{Binding IsSelected}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Name" Width="220">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Description" Width="400">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Package" Width="240">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding WingetId}" Foreground="{StaticResource TextSecondaryBrush}" />
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Border>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Features">
                        <views:FeaturesView DataContext="{Binding Features}" />
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Optimization content -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Optimization}">

                <!-- Category list (visible when no sub-category is selected) -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Optimization.ShowCategories}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="14"
                            Padding="14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Optimization"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="Select a category to optimize your system."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,14,0,0"
                            Background="{StaticResource SurfaceAltBrush}"
                            Padding="10"
                            CornerRadius="14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Optimization.Categories}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.Optimization.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Key}"
                                                Margin="4,4"
                                                FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="cardBorder"
                                                            Background="{StaticResource SurfaceBrush}"
                                                            CornerRadius="12"
                                                            Padding="16,14"
                                                            BorderBrush="{StaticResource BorderBrushMono}"
                                                            BorderThickness="1"
                                                            Cursor="Hand">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="14"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                                <TextBlock Text="{Binding Description}"
                                                                           Margin="0,4,0,0"
                                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="›"
                                                                       FontSize="22"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource MutedBrush}"
                                                                       Margin="12,0,4,0" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="cardBorder" Property="Background"
                                                                    Value="{StaticResource SurfaceAltBrush}" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="cardBorder" Property="Background"
                                                                    Value="{StaticResource PrimaryLightBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- Category detail view (visible when a sub-category is selected) -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Optimization.ShowCategories}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="14"
                            Padding="14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Content="← Back"
                                    Command="{Binding Optimization.GoBackCommand}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Optimization.CurrentCategoryView.Title}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>
                    </Border>

                    <ContentControl Grid.Row="1"
                                    Margin="0,14,0,0"
                                    Content="{Binding Optimization.CurrentCategoryView}"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch">
                        <ContentControl.Resources>
                            <DataTemplate DataType="{x:Type optvm:PrivacySecurityViewModel}">
                                <optv:PrivacySecurityView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type optvm:PowerViewModel}">
                                <optv:PowerView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type optvm:GamingPerformanceViewModel}">
                                <optv:GamingPerformanceView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type optvm:UpdateViewModel}">
                                <optv:UpdateView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type optvm:NotificationsViewModel}">
                                <optv:NotificationsView />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type optvm:SoundViewModel}">
                                <optv:SoundView />
                            </DataTemplate>
                        </ContentControl.Resources>
                    </ContentControl>
                </Grid>
            </Grid>

            <!-- Customization placeholder -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Customization}">
                <TextBlock Text="{Binding CustomizationMessage}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>

            <!-- Misc -->
            <Grid Visibility="{Binding SelectedSection, Converter={StaticResource SectionToVisibilityConverter}, ConverterParameter=Misc}">
                <views:MiscView DataContext="{Binding Misc}" />
            </Grid>
        </Grid>
    </Grid>
</Window>

