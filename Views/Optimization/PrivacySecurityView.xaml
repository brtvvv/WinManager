<UserControl x:Class="WinManager.Views.Optimization.PrivacySecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                Padding="20"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- UAC Setting Row (unchanged) -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="16,14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="UAC Control Level"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="UAC notification level change"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding UacOptions}"
                                      SelectedItem="{Binding SelectedUacOption, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="320"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- DNS Provider Row -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="16,14"
                            Margin="0,8,0,0"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="DNS Provider"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Change DNS servers and enable DNS over HTTPS"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding DnsProviders}"
                                      SelectedItem="{Binding SelectedDnsProvider, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="240"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Privacy Toggle Groups -->
                    <ItemsControl ItemsSource="{Binding ToggleGroups}" Margin="0,6,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,12,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource SurfaceBrush}"
                                                        CornerRadius="8"
                                                        Padding="14,9"
                                                        Margin="0,3"
                                                        BorderBrush="{StaticResource BorderBrushMono}"
                                                        BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Name}" Value="Allow Cortana" />
                                                                        <Condition Binding="{Binding DataContext.IsCortanaAvailable, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False" />
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                                            <TextBlock Text="{Binding Description}"
                                                                       FontSize="11"
                                                                       Margin="0,2,0,0"
                                                                       Foreground="{StaticResource TextSecondaryBrush}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding StatusText}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Margin="0,0,14,0"
                                                                   MinWidth="75"
                                                                   TextAlignment="Right">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsChecking}" Value="True">
                                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Button Grid.Column="2"
                                                                Content="{Binding ButtonLabel}"
                                                                Command="{Binding DataContext.TogglePrivacyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                MinWidth="70"
                                                                VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status toast / snackbar -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1"
                Background="{StaticResource SurfaceBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowStatus}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding DismissStatusCommand}"
                        VerticalAlignment="Center"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
