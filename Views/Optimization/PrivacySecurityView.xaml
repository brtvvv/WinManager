<UserControl x:Class="WinManager.Views.Optimization.PrivacySecurityView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                Padding="20"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- UAC Setting Row -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="16,14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="UAC Control Level"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="UAC notification level change"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding UacOptions}"
                                      SelectedItem="{Binding SelectedUacOption, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="320"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status toast / snackbar -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1"
                Background="{StaticResource SurfaceBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowStatus}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding DismissStatusCommand}"
                        VerticalAlignment="Center"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
