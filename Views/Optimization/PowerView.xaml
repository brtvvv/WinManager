<UserControl x:Class="WinManager.Views.Optimization.PowerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                Padding="20"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Plan Selector -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="16,14"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Power Plan"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Select active power plan"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Plans}"
                                      SelectedItem="{Binding SelectedPlan, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="280"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Hibernate Toggle -->
                    <Border Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10"
                            Padding="16,14"
                            Margin="0,12,0,0"
                            BorderBrush="{StaticResource BorderBrushMono}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Hibernate"
                                           FontWeight="SemiBold"
                                           FontSize="14"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock Text="Enable or disable hibernation"
                                           Margin="0,4,0,0"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding HibernateStatusText}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0"
                                       MinWidth="75"
                                       TextAlignment="Right">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HibernateEnabled}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Grid.Column="2"
                                    Content="{Binding HibernateButtonLabel}"
                                    Command="{Binding ToggleHibernateCommand}"
                                    MinWidth="70"
                                    VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <!-- Settings Sections -->
                    <ItemsControl ItemsSource="{Binding Settings}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,8,0,0"
                                        Background="{StaticResource SurfaceBrush}"
                                        CornerRadius="8"
                                        Padding="14,12"
                                        BorderBrush="{StaticResource BorderBrushMono}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />

                                        <!-- AC / DC columns -->
                                        <Grid Margin="0,10,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- AC (Plugged in) -->
                                            <StackPanel Margin="0,0,6,0">
                                                <TextBlock Text="Plugged in"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <ComboBox ItemsSource="{Binding Options}"
                                                          SelectedItem="{Binding SelectedAcOption, Mode=TwoWay}"
                                                          DisplayMemberPath="Label">
                                                    <ComboBox.Style>
                                                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSlider}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.Style>
                                                </ComboBox>
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSlider}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBox Text="{Binding AcInput, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="52"
                                                             VerticalAlignment="Center"
                                                             Padding="4,3"
                                                             FontSize="12" />
                                                    <TextBlock Text="%"
                                                               VerticalAlignment="Center"
                                                               Margin="3,0,6,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Button Content="✓"
                                                            Command="{Binding ApplyAcCommand}"
                                                            VerticalAlignment="Center"
                                                            Padding="7,3"
                                                            FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- DC (On battery) -->
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="On battery"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,0,4" />
                                                <ComboBox ItemsSource="{Binding Options}"
                                                          SelectedItem="{Binding SelectedDcOption, Mode=TwoWay}"
                                                          DisplayMemberPath="Label">
                                                    <ComboBox.Style>
                                                        <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSlider}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ComboBox.Style>
                                                </ComboBox>
                                                <StackPanel Orientation="Horizontal">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSlider}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBox Text="{Binding DcInput, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="52"
                                                             VerticalAlignment="Center"
                                                             Padding="4,3"
                                                             FontSize="12" />
                                                    <TextBlock Text="%"
                                                               VerticalAlignment="Center"
                                                               Margin="3,0,6,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <Button Content="✓"
                                                            Command="{Binding ApplyDcCommand}"
                                                            VerticalAlignment="Center"
                                                            Padding="7,3"
                                                            FontSize="12" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status toast -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1"
                Background="{StaticResource SurfaceBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowStatus}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding DismissStatusCommand}"
                        VerticalAlignment="Center"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
