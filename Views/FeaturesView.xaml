<UserControl x:Class="WinManager.Views.FeaturesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="FeatureItemTemplate">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="14,9"
                    Margin="0,3"
                    BorderBrush="{StaticResource BorderBrushMono}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding Name}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button Grid.Column="1"
                            Content="{Binding ButtonLabel}"
                            Command="{Binding DataContext.ExecuteFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            MinWidth="70"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="EnableFeatureItemTemplate">
            <Border Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="14,9"
                    Margin="0,3"
                    BorderBrush="{StaticResource BorderBrushMono}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="May not work on 22H2+"
                                   Foreground="Orange"
                                   FontSize="10"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding Name}" Value="Legacy Media" />
                                                <Condition Binding="{Binding DataContext.IsLegacyMediaSupported, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Visibility" Value="Visible" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0"
                               MinWidth="75"
                               TextAlignment="Right">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsChecking}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Grid.Column="2"
                            Content="{Binding ButtonLabel}"
                            Command="{Binding DataContext.ToggleFeatureCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            MinWidth="70"
                            VerticalAlignment="Center" />
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceAltBrush}"
                CornerRadius="14"
                Padding="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Download -->
                    <TextBlock Text="Download"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{Binding DownloadItems}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}" />

                    <!-- Enable -->
                    <TextBlock Text="Enable"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,18,0,8"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{Binding EnableItems}"
                                  ItemTemplate="{StaticResource EnableFeatureItemTemplate}" />

                    <!-- Run -->
                    <TextBlock Text="Run"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,18,0,8"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <ItemsControl ItemsSource="{Binding RunItems}"
                                  ItemTemplate="{StaticResource FeatureItemTemplate}" />

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status toast -->
        <Border Grid.Row="1"
                CornerRadius="10"
                Padding="14,10"
                Margin="0,10,0,0"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1"
                Background="{StaticResource SurfaceBrush}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowStatus}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusMessage}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding DismissStatusCommand}"
                        VerticalAlignment="Center"
                        Padding="6,2"
                        Margin="8,0,0,0"
                        FontSize="12" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
