<UserControl x:Class="WinManager.Views.MiscView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="{StaticResource SurfaceBrush}"
                CornerRadius="14"
                Padding="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="System Panels"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Quick access to Windows system panels and settings."
                           Margin="0,6,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Background="{StaticResource SurfaceAltBrush}"
                Padding="10"
                CornerRadius="14"
                BorderBrush="{StaticResource BorderBrushMono}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Panels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.OpenPanelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Margin="0,3"
                                    FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="itemBorder"
                                                Background="{StaticResource SurfaceBrush}"
                                                CornerRadius="8"
                                                Padding="14,10"
                                                BorderBrush="{StaticResource BorderBrushMono}"
                                                BorderThickness="1"
                                                Cursor="Hand">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                <TextBlock Grid.Column="1"
                                                           Text="›"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource MutedBrush}"
                                                           Margin="12,0,4,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="itemBorder" Property="Background"
                                                        Value="{StaticResource SurfaceAltBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="itemBorder" Property="Background"
                                                        Value="{StaticResource PrimaryLightBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
